# Copy this file to .env and fill in your credentials
# cp .env.example .env

# ConnectWise portal URL (the base URL you log into)
CW_URL=https://your-cw-instance.connectwise.com

# ConnectWise login credentials
CW_USERNAME=your.username@carolinaday.org
CW_PASSWORD=your_password_here

# Dashboard password (the one users enter on the login screen)
# This is used only for reference — the actual check is in index.html
DASHBOARD_PASSWORD=CDS1*4u

# Server port (default: 3000)
PORT=3000

# ── Supabase (persistent storage) ────────────────────────────────────────────
# Create a free project at supabase.com, then get these from Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Microsoft Teams (Graph API) ───────────────────────────────────────────────
# Azure AD app registration credentials (from portal.azure.com)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Teams chat ID to pull messages from (group chat or 1:1)
# Get it from Teams web: open the chat, copy the URL — the chat ID is the long string
# after /conversations/ that looks like: 19:xxxxxxxx_xxxxxxxx@unq.gbl.spaces
# Or use Graph Explorer: GET https://graph.microsoft.com/v1.0/me/chats
TEAMS_CHAT_ID=19:your-chat-id-here@unq.gbl.spaces
